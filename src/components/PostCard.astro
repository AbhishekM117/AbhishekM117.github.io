---
import type { CollectionEntry } from "astro:content";
interface Props {
  post: CollectionEntry<"blog">;
}
const { post } = Astro.props;
const { data } = post;
const dateStr = data.pubDate.toLocaleDateString("en-GB", {
  day: "2-digit",
  month: "short",
  year: "numeric",
});
---

<a class="card" href={`/blog/${post.id}`} data-tilt data-reveal>
  {data.cover && (
    <div class="card__cover">
      <img src={data.cover} alt="" />
    </div>
  )}
  <div class="card__kicker">
    <span>{data.pillar}</span>
    <span>{dateStr}</span>
  </div>
  <h3 class="card__title">{data.title}</h3>
  <p class="card__desc">{data.description}</p>
  <span class="card__foot">Read post <span class="arrow">→</span></span>
</a>
